# Employment Case Summaries — Environment Variables
# 
# Copy this file to .env.local and fill in your values.
# Secrets should ONLY be set via wrangler CLI, not here:
#   wrangler secret put OPENROUTER_API_KEY
#   wrangler secret put ADMIN_SECRET

# ─── LLM & OpenRouter ─────────────────────────────────────────────────────
# Your OpenRouter API key (https://openrouter.ai/)
# Set via: wrangler secret put OPENROUTER_API_KEY
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# LLM model to use for summarization
# Recommend: anthropic/claude-3.5-sonnet-20241022 (best quality)
# Or: anthropic/claude-3-opus (faster, still good)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet-20241022

# ─── Admin Authentication ────────────────────────────────────────────────
# Admin password for /admin dashboard
# Set via: wrangler secret put ADMIN_SECRET
ADMIN_SECRET=YourAdminPasswordHere123

# ─── Email Configuration ────────────────────────────────────────────────
# Domain that sends emails (must be verified in Cloudflare Email Service)
SENDING_ADDRESS=digest@yourdomain.com

# Admin email address (receives error alerts)
ADMIN_EMAIL=admin@yourdomain.com

# ─── Website URLs ──────────────────────────────────────────────────────
# Your site's base URL (used in emails for unsubscribe links)
SITE_URL=https://yourdomain.com

# ERA scraping source URL (usually doesn't change)
SOURCE_URL=https://determinations.era.govt.nz/determinations/recent

# ─── System Configuration ──────────────────────────────────────────────
# Timezone for cron triggers (must match your region)
# NZ: Pacific/Auckland
# US: America/New_York
# AU: Australia/Sydney
TIMEZONE=Pacific/Auckland

# Trigger mode: "scheduled" (daily) or "change_detection" (every 30 min)
# Default: "scheduled" (daily at 8am NZT)
TRIGGER_MODE=scheduled

# ─── Database Configuration ────────────────────────────────────────────
# D1 database ID (from 'wrangler d1 create era-digest')
# Don't change this unless you create a new database
D1_DATABASE_ID=0c0edb97-2257-4a72-9637-c98799984715

# ─── PDF Processing ────────────────────────────────────────────────────
# For ERA PDFs: false = local extraction (FlateDecode)
# For EC PDFs: requires Python sidecar (pdf-parser-python worker)
USE_PDF_URL_PASSTHROUGH=false
